# =============================================================
# WINE CHANNEL — AUTOMAZIONE COMMERCIALE
# Copia questo file in .env e compila con i tuoi valori reali
# MAI committare il file .env nel repository
# =============================================================

# --- META / WHATSAPP BUSINESS API ---
# Ottieni da: Meta Developer Console → App → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_BUSINESS_ACCOUNT_ID=123456789012345
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxx
# Token di verifica webhook (sceglilo tu, stringa casuale)
WHATSAPP_WEBHOOK_VERIFY_TOKEN=wine_channel_secret_2026

# --- SUITECRM ---
# URL senza slash finale
SUITECRM_URL=https://crm.tuodominio.it
SUITECRM_USERNAME=admin
SUITECRM_PASSWORD=password_sicura
# Oppure usa API key V8 (consigliato)
SUITECRM_API_KEY=your_api_key_here

# --- N8N ---
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
# Usato come base URL per i webhook
N8N_WEBHOOK_URL=https://n8n.tuodominio.it
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=password_sicura

# --- BROADCAST (modificare prima di ogni campagna) ---
# Tipo cliente da targetare: buyer | importatore | distributore | sommelier | privato
BROADCAST_TIPO_CLIENTE=buyer
# Tag evento in SuiteCRM (es. Vinitaly2026)
BROADCAST_TAG_EVENTO=Vinitaly2026
# Nome del template Meta approvato
BROADCAST_TEMPLATE_NAME=invito_masterclass
# Testo variabili per il template broadcast
BROADCAST_NOME_EVENTO=Vinitaly 2026
BROADCAST_DATA_EVENTO=7-10 Aprile 2026

# --- MATERIALI POST-EVENTO ---
# Base URL dove sono hostati i materiali (schede vino, foto)
LINK_MATERIALI_BASE=https://materiali.winechannel.it

# --- DASHBOARD ---
DASHBOARD_PORT=8080
# Timezone per orario lavorativo (verifica fuori-orario)
TIMEZONE=Europe/Rome
# Orario inizio/fine lavoro (formato 24h)
ORARIO_INIZIO=9
ORARIO_FINE=18
